# Bitescore mobile — copy to .env and fill in. Never commit .env.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle; keep secrets out of here.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bitescore server (Vercel) — powers the Google Places lookup, not secret.
EXPO_PUBLIC_SERVER_URL=https://bitescore.vercel.app

# RevenueCat public SDK keys (safe to ship in the client)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx
