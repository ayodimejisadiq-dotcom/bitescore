# Bitescore server (Vercel) — copy to .env and fill in. Never commit .env.
# These are SERVER-ONLY secrets. Never expose the service-role key to the app.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Places (opening hours). Restrict the key to the Places API.
GOOGLE_PLACES_API_KEY=your-places-key

# RevenueCat webhook shared secret (Authorization header the webhook must send)
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret

# Protects the cron endpoints from public invocation (Vercel Cron sends this).
CRON_SECRET=your-cron-secret

# Optional: address to email the moderation queue digest to.
MODERATION_ALERT_EMAIL=you@example.com
