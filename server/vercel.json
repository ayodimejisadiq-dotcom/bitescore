{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/cron/ingest.ts": { "maxDuration": 60 },
    "api/cron/notify.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/ingest", "schedule": "0 3 * * *" },
    { "path": "/api/cron/notify", "schedule": "0 * * * *" }
  ]
}
